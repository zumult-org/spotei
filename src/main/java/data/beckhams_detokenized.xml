      <body>
         <annotationBlock xml:id="ab_d2e203" who="SPK0" start="T30" end="T33">
            <u xml:id="u_d2e203">
               <tei:seg xmlns:tei="http://www.tei-c.org/ns/1.0" type="contribution" xml:id="d2e197"><tei:anchor synch="T30"/>I mean did you think: <anchor synch="T3"/> "Good God <anchor synch="T4"/>this/ <anchor synch="T5"/>this is the guy, <anchor synch="T31"/>this is the girl I' m gonna get married to and live the rest of my life with?" <anchor synch="T32"/>((0,4s)) David?<tei:anchor synch="T33"/></tei:seg>
            </u>
            <spanGrp type="c"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T3" to="T32">Reported speech </tei:span></spanGrp>
            <spanGrp type="de"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T30" to="T3">Ich meine, dachtest Du:  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T3" to="T4">"Lieber Gott,  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T4" to="T5">das/  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T5" to="T31">das ist der Kerl,  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T31" to="T32">das ist das Mädchen das ich heiraten werde und mit dem ich den Rest meines Lebens verbringe?"  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T32" to="T33">((0,4s)) David?  </tei:span></spanGrp>
            <spanGrp type="df"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T4" to="T5">TROUBLE </tei:span></spanGrp>
         </annotationBlock>
         <annotationBlock xml:id="ab_d2e305" who="SPK2" start="T33" end="T34">
            <u xml:id="u_d2e305">
               <tei:seg xmlns:tei="http://www.tei-c.org/ns/1.0" type="contribution" xml:id="d2e247"><tei:anchor synch="T33"/>I felt that, yeah.<tei:anchor synch="T34"/></tei:seg>
            </u>
            <spanGrp type="de"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T33" to="T34">Ich habe das gefühlt, ja.  </tei:span></spanGrp>
         </annotationBlock>
         <annotationBlock xml:id="ab_d2e222" who="SPK0" start="T34" end="T2">
            <u xml:id="u_d2e222">
               <tei:seg xmlns:tei="http://www.tei-c.org/ns/1.0" type="contribution" xml:id="d2e259"><tei:anchor synch="T34"/>Did you?<tei:anchor synch="T2"/></tei:seg>
            </u>
            <spanGrp type="de"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T34" to="T2">Hast Du?  </tei:span></spanGrp>
         </annotationBlock>
         <annotationBlock xml:id="ab_d2e308" who="SPK2" start="T2" end="T36">
            <u xml:id="u_d2e308">
               <tei:seg xmlns:tei="http://www.tei-c.org/ns/1.0" type="contribution" xml:id="d2e271"><tei:anchor synch="T2"/>Definitely. <anchor synch="T35"/>You did I hope, didn' t you?<tei:anchor synch="T36"/></tei:seg>
            </u>
            <spanGrp type="de"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T2" to="T35">Definitiv.  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T35" to="T36">Du auch, hoffe ich, oder?  </tei:span></spanGrp>
         </annotationBlock>
         <annotationBlock xml:id="ab_d2e275" who="SPK1" start="T36" end="T38">
            <u xml:id="u_d2e275">
               <tei:seg xmlns:tei="http://www.tei-c.org/ns/1.0" type="contribution" xml:id="d2e288"><tei:anchor synch="T36"/>((0,3s)) Yeah.<anchor synch="T37"/>((laughing)) <tei:anchor synch="T38"/></tei:seg>
            </u>
            <spanGrp type="de"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T36" to="T37">((0,3s)) Ja.  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T37" to="T38">((lacht))  </tei:span></spanGrp>
         </annotationBlock>
         <annotationBlock xml:id="ab_d2e225" who="SPK0" start="T37" end="T40">
            <u xml:id="u_d2e225">
               <tei:seg xmlns:tei="http://www.tei-c.org/ns/1.0" type="contribution" xml:id="d2e306"><tei:anchor synch="T37"/>((laughing)) <anchor synch="T38"/>Was <anchor synch="T39"/>it really like that?<tei:anchor synch="T40"/></tei:seg>
            </u>
            <spanGrp type="de"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T37" to="T38">((lacht))  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T38" to="T40">War es wirklich so?  </tei:span></spanGrp>
         </annotationBlock>
         <annotationBlock xml:id="ab_d2e314" who="SPK2" start="T37" end="T46">
            <u xml:id="u_d2e314">
               <tei:seg xmlns:tei="http://www.tei-c.org/ns/1.0" type="contribution" xml:id="d2e325"><tei:anchor synch="T37"/>((laughing)) <anchor synch="T38"/>Yeah. <anchor synch="T39"/>Yeah, yeah, <anchor synch="T6"/>I was/ I was/ <anchor synch="T40"/>it was definitely. <anchor synch="T41"/>((0,3s)) As soon as <anchor synch="T42"/>I see <anchor synch="T43"/>her. <anchor synch="T44"/>You know, I didn' t even have to meet her. <anchor synch="T45"/>I seen her on the telly and I just wanted to meet her.<tei:anchor synch="T46"/></tei:seg>
            </u>
            <spanGrp type="de"><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T37" to="T38">((lacht))  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T38" to="T39">Ja.  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T39" to="T6">Ja, ja,  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T6" to="T40">ich war/ ich war/  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T40" to="T41">es war definitiv so.  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T41" to="T44">Sobald ich sie gesehen habe.  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T44" to="T45">Weißt Du, ich musste sie noch nicht mal treffen.  </tei:span><tei:span xmlns:tei="http://www.tei-c.org/ns/1.0" from="T45" to="T46">Ich habe sie im Fernsehen gesehen und ich wollte sie einfach treffen.  </tei:span></spanGrp>
