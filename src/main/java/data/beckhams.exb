        <tier id="TIE7" speaker="SPK0" category="c" type="a" display-name="PAR [c]">
            <event start="T3" end="T32">Reported speech</event>
        </tier>
        <tier id="TIE0" speaker="SPK0" category="v" type="t" display-name="PAR [v]">
            <event start="T30" end="T3">I mean did you think: </event>
            <event start="T3" end="T4">"Good God </event>
            <event start="T4" end="T5">this/ </event>
            <event start="T5" end="T31">this is the guy, </event>
            <event start="T31" end="T32">this is the girl I'm gonna get married to and live the rest of my life with?" </event>
            <event start="T32" end="T33">((0,4s)) David? </event>
            <event start="T34" end="T2">Did you? </event>
            <event start="T37" end="T38">((laughing)) </event>
            <event start="T38" end="T39">Was </event>
            <event start="T39" end="T40">it really like that? </event>
        </tier>
        <tier id="TIE4" speaker="SPK0" category="de" type="a" display-name="PAR [de]">
            <event start="T30" end="T3">Ich meine, dachtest Du: </event>
            <event start="T3" end="T4">"Lieber Gott, </event>
            <event start="T4" end="T5">das/ </event>
            <event start="T5" end="T31">das ist der Kerl, </event>
            <event start="T31" end="T32">das ist das Mädchen das ich heiraten werde und mit dem ich den Rest meines Lebens verbringe?" </event>
            <event start="T32" end="T33">((0,4s)) David? </event>
            <event start="T34" end="T2">Hast Du? </event>
            <event start="T37" end="T38">((lacht)) </event>
            <event start="T38" end="T40">War es wirklich so? </event>
        </tier>
        <tier id="TIE8" speaker="SPK0" category="df" type="a" display-name="PAR [df]">
            <event start="T4" end="T5">TROUBLE</event>
        </tier>
        <tier id="TIE1" speaker="SPK1" category="v" type="t" display-name="VIC [v]">
            <event start="T36" end="T37">((0,3s)) Yeah. </event>
            <event start="T37" end="T38">((laughing))</event>
            <event start="T40" end="T41">((laughing)) </event>
            <event start="T42" end="T43">((laughing)) </event>
        </tier>
        <tier id="TIE6" speaker="SPK1" category="de" type="a" display-name="VIC [de]">
            <event start="T36" end="T37">((0,3s)) Ja. </event>
            <event start="T37" end="T38">((lacht)) </event>
            <event start="T40" end="T41">((lacht)) </event>
            <event start="T42" end="T43">((lacht)) </event>
        </tier>
        <tier id="TIE2" speaker="SPK2" category="v" type="t" display-name="DAV [v]">
            <event start="T33" end="T34">I felt that, yeah. </event>
            <event start="T2" end="T35">Definitely. </event>
            <event start="T35" end="T36">You did I hope, didn't you? </event>
            <event start="T37" end="T38">((laughing)) </event>
            <event start="T38" end="T39">Yeah. </event>
            <event start="T39" end="T6">Yeah, yeah, </event>
            <event start="T6" end="T40">I was/ I was/ </event>
            <event start="T40" end="T41">it was definitely. </event>
            <event start="T41" end="T42">((0,3s)) As soon as </event>
            <event start="T42" end="T43">I see </event>
            <event start="T43" end="T44">her. </event>
            <event start="T44" end="T45">You know, I didn't even have to meet her. </event>
            <event start="T45" end="T46">I seen her on the telly and I just wanted to meet her. </event>
        </tier>
        <tier id="TIE5" speaker="SPK2" category="de" type="a" display-name="DAV [de]">
            <event start="T33" end="T34">Ich habe das gefühlt, ja. </event>
            <event start="T2" end="T35">Definitiv. </event>
            <event start="T35" end="T36">Du auch, hoffe ich, oder? </event>
            <event start="T37" end="T38">((lacht)) </event>
            <event start="T38" end="T39">Ja. </event>
            <event start="T39" end="T6">Ja, ja, </event>
            <event start="T6" end="T40">ich war/ ich war/ </event>
            <event start="T40" end="T41">es war definitiv so. </event>
            <event start="T41" end="T44">Sobald ich sie gesehen habe. </event>
            <event start="T44" end="T45">Weißt Du, ich musste sie noch nicht mal treffen. </event>
            <event start="T45" end="T46">Ich habe sie im Fernsehen gesehen und ich wollte sie einfach treffen. </event>
        </tier>
        <tier id="TIE9" speaker="SPK2" category="df" type="a" display-name="DAV [df]">
            <event start="T6" end="T40">TROUBLE</event>
            <event start="T40" end="T41">RESTART</event>
        </tier>
